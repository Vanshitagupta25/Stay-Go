<% layout("/layouts/boilerplate") %>

<style>
  .auth-container {
    min-height: 85vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 1rem;
  }

  .auth-card {
    width: 100%;
    max-width: 450px;
    background: #fff;
    border-radius: 18px;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .auth-logo {
    text-align: center;
    font-size: 2rem;
    color: #fe424d;
    margin-bottom: 1rem;
  }

  .auth-title {
    text-align: center;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    text-align: center;
    color: #6c757d;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .form-label {
    font-weight: 500;
  }

  .form-control {
    padding: 0.85rem 1rem;
    border-radius: 10px;
  }

  .form-control:focus {
    border-color: #fe424d;
    box-shadow: 0 0 0 0.2rem rgba(254, 66, 77, 0.15);
  }

  .auth-btn {
    width: 100%;
    background-color: #fe424d;
    border: none;
    padding: 0.9rem;
    border-radius: 10px;
    font-weight: 600;
    transition: 0.3s;
  }

  .auth-btn:hover {
    background-color: #e63946;
  }

  .auth-footer {
    text-align: center;
    margin-top: 1.25rem;
    color: #6c757d;
  }

  .auth-footer a {
    color: #fe424d;
    text-decoration: none;
    font-weight: 600;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 576px) {
    .auth-card {
      padding: 1.5rem;
    }

    .auth-title {
      font-size: 1.6rem;
    }
  }
</style>

<div class="auth-container">
  <div class="auth-card">

    <div class="auth-logo">
      <i class="fa-solid fa-compass"></i>
    </div>

    <h2 class="auth-title">Create Account</h2>

    <p class="auth-subtitle">
      Join Stay-Go and start exploring amazing stays.
    </p>

    <form action="/signup" method="post">

      <div class="mb-3">
        <label class="form-label">Username</label>
        <input
          type="text"
          name="username"
          class="form-control"
          placeholder="Choose a username"
          required
        >
      </div>

      <div class="mb-3">
        <label class="form-label">Email</label>
        <input
          type="email"
          name="email"
          class="form-control"
          placeholder="Enter your email"
          required
        >
      </div>

      <div class="mb-4">
        <label class="form-label">Password</label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="Create a password"
          required
        >
      </div>

      <button type="submit" class="btn auth-btn">
        Create Account
      </button>

    </form>

    <div class="auth-footer">
      Already have an account?
      <a href="/login">Login</a>
    </div>

  </div>
</div>